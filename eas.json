{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "env": {
        "EAS_SKIP_AUTO_FINGERPRINT": "1",
        "EXPO_NO_FINGERPRINT": "1",
        "RCT_BUILD_HERMES_FROM_SOURCE": "1",
        "BUILD_FROM_SOURCE": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
